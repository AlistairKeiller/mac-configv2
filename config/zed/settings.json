  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Mocha",
  },
  "lsp": {
    "tinymist": {
      "initialization_options": {
        "preview": {
          "background": {
            "enabled": true,
          },
        },
      },
    },
  },
